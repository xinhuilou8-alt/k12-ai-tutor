# ═══════════════════════════════════════════
# K12 AI辅导 — AI 服务配置
# ═══════════════════════════════════════════
# 复制此文件为 .env 并填入你的 API Key
# cp .env.example .env

# ── LLM 大模型服务 ──────────────────────
# 主 provider（第一优先）: openai | baidu | qwen | mock
LLM_PROVIDER=mock

# Fallback 顺序（可选）：主 provider 失败时依次尝试
# 不配置时自动检测已填 Key 的 provider 作为 fallback
# 例如: LLM_FALLBACK=qwen,mock  → 调用链: openai → qwen → mock
LLM_FALLBACK=

# 可以同时填写多个 Key！调用逻辑：
# 1. 先调用 LLM_PROVIDER 指定的主 provider
# 2. 失败时按 LLM_FALLBACK 顺序（或自动检测顺序）尝试下一个
# 3. 最终兜底 mock（返回固定文本）
#
# 示例：三个都填了，LLM_PROVIDER=openai
# → 调用链: openai → qwen → mock

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 百度文心一言
BAIDU_API_KEY=
BAIDU_SECRET_KEY=
BAIDU_MODEL=ernie-4.0-8k

# 阿里通义千问
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# ── OCR 文字识别 ────────────────────────
# 选择一个 provider: baidu_ocr | tencent_ocr | mock
OCR_PROVIDER=mock

# 百度 OCR
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

# 腾讯 OCR
TENCENT_OCR_SECRET_ID=
TENCENT_OCR_SECRET_KEY=

# ── ASR 语音识别 ────────────────────────
# 选择一个 provider: baidu_asr | tencent_asr | mock
ASR_PROVIDER=mock

# 百度 ASR
BAIDU_ASR_APP_ID=
BAIDU_ASR_API_KEY=
BAIDU_ASR_SECRET_KEY=

# ── TTS 语音合成 ────────────────────────
# 选择一个 provider: baidu_tts | tencent_tts | mock
TTS_PROVIDER=mock

# 百度 TTS
BAIDU_TTS_APP_ID=
BAIDU_TTS_API_KEY=
BAIDU_TTS_SECRET_KEY=

# ── 服务端口 ────────────────────────────
PORT=3210
