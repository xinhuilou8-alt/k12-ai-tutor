{
  "name": "k12-homework-ai-tutor",
  "version": "0.1.0",
  "private": true,
  "description": "K12家庭作业AI辅导产品 - 微服务架构",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "npx ts-node --skip-project --compiler-options '{\"module\":\"commonjs\",\"moduleResolution\":\"node\",\"esModuleInterop\":true,\"strict\":false}' packages/demo-server/src/server.ts",
    "build": "tsc --build tsconfig.json",
    "lint": "eslint 'packages/*/src/**/*.ts'",
    "test": "jest --passWithNoTests",
    "demo": "npx ts-node --skip-project --compiler-options '{\"module\":\"commonjs\",\"moduleResolution\":\"node\",\"esModuleInterop\":true,\"strict\":false}' demo.ts",
    "demo:ui": "open demo-ui.html",
    "demo:server": "npx ts-node --skip-project --compiler-options '{\"module\":\"commonjs\",\"moduleResolution\":\"node\",\"esModuleInterop\":true,\"strict\":false}' packages/demo-server/src/server.ts",
    "test:watch": "jest --watch",
    "clean": "rm -rf packages/*/dist"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "dotenv": "^17.4.1"
  }
}
